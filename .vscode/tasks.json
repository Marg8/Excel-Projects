{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Power Query Tester (browser)",
            "type": "shell",
            "command": "streamlit run app.py --server.port 8501 --server.headless true",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": "You can now view"
                }
            }
        }
    ]
}
